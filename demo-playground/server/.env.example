# Copy to .env.local and customize (start.sh sources it automatically).
#
# Optional Bearer token for remote demo server access:
# ALKAHEST_SERVER_TOKEN=your-secret-token
#
# Force reinstall from GitHub +full wheel instead of local maturin develop:
# ALKAHEST_USE_RELEASE_WHEEL=1
#
# Rebuild local alkahest even when sources have not changed:
# ALKAHEST_FORCE_REBUILD=1
